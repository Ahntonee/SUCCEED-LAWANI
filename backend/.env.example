# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=https://your-site.vercel.app

# ─── Admin Seed Credentials ───────────────────────────────────────────────────
ADMIN_EMAIL=hello@succeedlawani.com
ADMIN_PASSWORD=change-this-password

# ─── Payments ─────────────────────────────────────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=paste-your-paystack-secret-key-here

# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=paste-your-stripe-secret-key-here

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: use an App Password — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Succeed Michael Lawani <hello@succeedlawani.com>
