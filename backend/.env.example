# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-site.vercel.app

# ─── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=hello@succeedlawani.com
ADMIN_PASSWORD=change-this-strong-password

# ─── Payments ─────────────────────────────────────────────────────────────────
# Paystack: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=paste-your-paystack-secret-key-here

# Flutterwave: https://developer.flutterwave.com/docs/api-keys
FLUTTERWAVE_SECRET_KEY=paste-your-flutterwave-secret-key-here

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=Succeed Michael Lawani <hello@succeedlawani.com>

# ─── Cloudinary (persistent file storage) ─────────────────────────────────────
# Free at cloudinary.com — required for images to survive Render redeploys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
